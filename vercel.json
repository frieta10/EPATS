{
  "version": 2,
  "builds": [
    { "src": "*.php",              "use": "vercel-php@0.7.2" },
    { "src": "admin/*.php",        "use": "vercel-php@0.7.2" },
    { "src": "api/*.php",          "use": "vercel-php@0.7.2" },
    { "src": "admin/partials/*.php","use": "vercel-php@0.7.2" }
  ],
  "routes": [
    { "src": "/admin/?$",         "dest": "/admin/index.php" },
    { "src": "/guest-portal/?$",  "dest": "/guest-portal.php" },
    { "src": "/setup/?$",         "dest": "/setup.php" },
    { "src": "/(.*\\.php.*)",     "dest": "/$1" },
    { "src": "/assets/(.*)",      "dest": "/assets/$1" },
    { "src": "/uploads/(.*)",     "dest": "/uploads/$1" },
    { "src": "/$",                "dest": "/index.php" }
  ]
}
